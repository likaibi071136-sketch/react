{
    "name": "react",
    "version": "1.0.0",
    "main": "index.js",
    "type": "module",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test:playwright": "turbo run test:playwright",
        "lint": "eslint",
        "lint:staged": "lint-staged",
        "format": "prettier --write .",
        "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md|tsx)\"",
        "commit": "git-cz",
        "prepare": "husky",
        "release": "semantic-release && conventional-changelog"
    },
    "keywords": [],
    "author": "LiKaibi",
    "license": "ISC",
    "description": "",
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-git"
        }
    },
    "lint-staged": {
        "*.{md,json}": [
            "prettier --cache --write --no-error-on-unmatched-pattern"
        ],
        "*.{css,less,scss,tsx}": [
            "stylelint --fix",
            "prettier --cache --write"
        ],
        "*.{js,jsx}": [
            "eslint --fix",
            "prettier --cache --write"
        ],
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier -6.0.2e --cache --parser=typescript"
        ]
    },
    "devDependencies": {
        "typescript": "6.0.2",
        "@types/node": "25.5.0",
        "eslint": "10.1.0",
        "@eslint/js": "10.0.1",
        "eslint-config-next": "16.2.1",
        "typescript-eslint": "8.57.2",
        "eslint-plugin-react-refresh": "0.5.2",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "globals": "17.4.0",
        "prettier": "3.8.1",
        "cspell": "9.7.0",
        "cz-git": "1.12.0",
        "commitizen": "4.3.1",
        "@commitlint/cli": "20.5.0",
        "@commitlint/config-conventional": "20.5.0",
        "@react-packages/commitlint-config-react": "workspace:*",
        "husky": "9.1.7",
        "commitlint": "20.5.0",
        "lint-staged": "16.4.0",
        "turbo": "2.8.20",
        "semantic-release": "25.0.3"
    }
}
